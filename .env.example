# ReportMind Environment Variables

# Get your API keys from:
# Groq: https://console.groq.com
# Tavily: https://app.tavily.com

GROQ_API_KEY=your_groq_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# Optional configuration
# MODEL_NAME=llama-3.3-70b-versatile
# TEMPERATURE=0
# MAX_SEARCH_RESULTS=5
# REPORT_DIR=reports/
# ----------------------------------------------------------------
# ReportMind - Environment Configuration Example
# ----------------------------------------------------------------
# Rename this file to .env and fill in your actual API keys.
# DO NOT commit your actual .env file to version control (GitHub).
# ----------------------------------------------------------------

# 1. Groq API Key
# Get your key from: https://console.groq.com/
# Used for the Llama-3.3-70b-versatile reasoning model.
GROQ_API_KEY=your_groq_api_key_here

# 2. Tavily Search API Key
# Get your key from: https://tavily.com/
# Provides the agent with real-time web search capabilities.
TAVILY_API_KEY=your_tavily_api_key_here

# 3. (Optional) Logging Configuration
# Set to 'DEBUG' to see full ReAct reasoning loops in the terminal.
LOG_LEVEL=INFO